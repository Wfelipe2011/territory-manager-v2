<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Saúde - Territory Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #121212;
            color: #E0E0E0;
            font-family: 'Inter', sans-serif;
        }
        .card {
            background-color: #1E1E1E;
            border-radius: 12px;
            padding: 1.5rem;
        }
        .progress-bar {
            background-color: #333;
            border-radius: 9999px;
            height: 0.5rem;
            overflow: hidden;
        }
        .progress-value {
            background-color: #4CAF50;
            height: 100%;
            transition: width 0.5s ease-in-out;
        }
        .table-row:nth-child(even) {
            background-color: #252525;
        }
    </style>
</head>
<body class="bg-[#121212] flex min-h-screen">
    {{> sidebar}}

    <!-- Main Content -->
    <main class="flex-1 md:ml-64 p-4 md:p-8">
        <div class="max-w-6xl mx-auto">
            <!-- Mobile Header with Menu Toggle -->
            <div class="flex md:hidden justify-between items-center mb-6">
                 <button onclick="toggleSidebar()" class="text-gray-400 p-2 hover:bg-gray-800 rounded-lg">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <h1 class="text-lg font-bold text-white">Saúde do Sistema</h1>
                <button onclick="refreshData()" class="text-gray-400 p-2 hover:bg-gray-800 rounded-lg">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>

            <!-- Header -->
            <header class="hidden md:flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-white">Saúde do Servidor</h1>
                    <p class="text-gray-400 text-sm mt-1">
                        Status técnico e infraestrutura global
                    </p>
                </div>
                <button onclick="refreshData()" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors">
                    <i class="fas fa-sync-alt" id="refresh-icon"></i>
                    <span>Atualizar</span>
                </button>
            </header>


            <!-- ... rest of the content ... -->
        <div class="card mb-6 border-l-4 border-green-500">
            <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                <p class="font-mono text-sm md:text-base text-gray-300" id="server-message">{{health.message}}</p>
            </div>
        </div>

        <!-- Metric Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            <!-- Signatures & Sockets -->
            <div class="grid grid-rows-2 gap-6">
                <div class="card flex justify-between items-center">
                    <div>
                        <p class="text-gray-400 text-sm uppercase font-semibold">Assinaturas</p>
                        <h2 class="text-3xl font-bold text-white mt-1" id="signatures-count">{{health.signatures}}</h2>
                    </div>
                    <i class="fas fa-file-signature text-green-500 text-2xl opacity-50"></i>
                </div>
                <div class="card flex justify-between items-center">
                    <div>
                        <p class="text-gray-400 text-sm uppercase font-semibold">Sockets</p>
                        <h2 class="text-3xl font-bold text-white mt-1" id="sockets-count">{{health.sockets}}</h2>
                    </div>
                    <i class="fas fa-plug text-green-500 text-2xl opacity-50"></i>
                </div>
            </div>

            <!-- Database Connections -->
            <div class="card">
                <div class="flex justify-between items-center mb-4">
                    <p class="text-gray-400 text-sm uppercase font-semibold">Banco de Dados</p>
                    <i class="fas fa-database text-green-500 opacity-50"></i>
                </div>
                <div class="space-y-4">
                    <div class="flex justify-between text-sm">
                        <span>Ativas: <span id="db-active" class="text-white font-bold">{{health.database_info.active}}</span></span>
                        <span>Ociosas: <span id="db-idle" class="text-white font-bold">{{health.database_info.idle}}</span></span>
                    </div>
                    <div>
                        <div class="flex justify-between text-xs mb-1">
                            <span>Uso de Conexões</span>
                            <span id="db-percent-text">{{dbPercent}}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-value" id="db-progress" style="width: {{dbPercent}}%"></div>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 text-right">Máximo: <span id="db-max">{{health.database_info.max_connections}}</span></p>
                </div>
            </div>

            <!-- Memory Usage -->
            <div class="card">
                <div class="flex justify-between items-center mb-4">
                    <p class="text-gray-400 text-sm uppercase font-semibold">Memória</p>
                    <i class="fas fa-memory text-green-500 opacity-50"></i>
                </div>
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-xs mb-1">
                            <span>Uso de Memória</span>
                            <span id="mem-percent-text">{{health.system_info.memory_usage_percent}}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-value" id="mem-progress" style="width: {{health.system_info.memory_usage_percent}}%"></div>
                        </div>
                    </div>
                    <div class="grid grid-cols-3 gap-2 text-center text-xs mt-4">
                        <div class="bg-gray-800 p-2 rounded">
                            <p class="text-gray-500 mb-1">Total</p>
                            <p id="mem-total" class="font-bold text-white">{{health.system_info.total_memory_mb}} MB</p>
                        </div>
                        <div class="bg-gray-800 p-2 rounded">
                            <p class="text-gray-500 mb-1">Usada</p>
                            <p id="mem-used" class="font-bold text-white">{{health.system_info.used_memory_mb}} MB</p>
                        </div>
                        <div class="bg-gray-800 p-2 rounded">
                            <p class="text-gray-500 mb-1">Livre</p>
                            <p id="mem-free" class="font-bold text-white">{{health.system_info.free_memory_mb}} MB</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CPU & System -->
            <div class="card lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <p class="text-gray-400 text-sm uppercase font-semibold mb-2">Uso de CPU</p>
                    <div class="flex items-end gap-3">
                        <h2 class="text-3xl font-bold text-white" id="cpu-percent">{{health.system_info.cpu_usage_percent}}%</h2>
                        <div class="flex-1 pb-2">
                             <div class="progress-bar">
                                <div class="progress-value" id="cpu-progress" style="width: {{health.system_info.cpu_usage_percent}}%"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <p class="text-gray-400 text-sm uppercase font-semibold mb-2">Tempo Ativo (Uptime)</p>
                    <h2 class="text-2xl font-bold text-white" id="uptime-text">{{uptimeFormatted}}</h2>
                </div>
                <div>
                    <p class="text-gray-400 text-sm uppercase font-semibold mb-2">Carga Média (Load Avg)</p>
                    <div class="flex gap-4 font-mono">
                        <div class="text-center">
                            <span id="load-1" class="text-white block font-bold">{{health.system_info.load_average.1_min}}</span>
                            <span class="text-[10px] text-gray-500">1m</span>
                        </div>
                        <div class="text-center">
                            <span id="load-5" class="text-white block font-bold">{{health.system_info.load_average.5_min}}</span>
                            <span class="text-[10px] text-gray-500">5m</span>
                        </div>
                        <div class="text-center">
                            <span id="load-15" class="text-white block font-bold">{{health.system_info.load_average.15_min}}</span>
                            <span class="text-[10px] text-gray-500">15m</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sessões WebSocket -->
        <div class="card mb-8">
            <div class="flex justify-between items-center mb-4">
                <p class="text-gray-400 text-sm uppercase font-semibold">Sessões WebSocket</p>
                <i class="fas fa-network-wired text-green-500 opacity-50"></i>
            </div>

            <!-- Filter Bar -->
            <div class="space-y-3 mb-4">
                <!-- Quick Filters Row -->
                <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
                    <!-- Period chips -->
                    <div class="flex items-center gap-1">
                        <span class="text-xs text-gray-500 mr-1 whitespace-nowrap">Período:</span>
                        <button data-period="1d" onclick="setPeriod('1d')" class="px-3 py-1 rounded-md text-xs font-semibold bg-green-700 text-white border border-green-600 transition-colors">1d</button>
                        <button data-period="3d" onclick="setPeriod('3d')" class="px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors">3d</button>
                        <button data-period="7d" onclick="setPeriod('7d')" class="px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors">7d</button>
                        <button data-period="custom" onclick="setPeriod('custom')" class="px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors">Personalizado</button>
                    </div>
                    <!-- Divider -->
                    <div class="hidden md:block w-px h-5 bg-gray-700"></div>
                    <!-- GroupBy chips -->
                    <div class="flex items-center gap-1">
                        <span class="text-xs text-gray-500 mr-1 whitespace-nowrap">Agrupar:</span>
                        <button data-groupby="10min" onclick="setGroupBy('10min')" class="px-3 py-1 rounded-md text-xs font-semibold bg-green-700 text-white border border-green-600 transition-colors">10min</button>
                        <button data-groupby="30min" onclick="setGroupBy('30min')" class="px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors">30min</button>
                        <button data-groupby="1h" onclick="setGroupBy('1h')" class="px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors">1h</button>
                        <button data-groupby="1d" onclick="setGroupBy('1d')" class="px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors">1d</button>
                    </div>
                    <!-- Divider -->
                    <div class="hidden md:block w-px h-5 bg-gray-700"></div>
                    <!-- Only Active toggle -->
                    <label class="flex items-center gap-2 cursor-pointer text-xs text-gray-400 hover:text-white transition-colors">
                        <input type="checkbox" id="toggle-only-active" onchange="toggleOnlyActive(this.checked)" class="rounded bg-gray-700 border-gray-600 text-green-600 focus:ring-green-600">
                        <span>Apenas com atividade</span>
                    </label>
                    <!-- Advanced toggle -->
                    <button onclick="toggleAdvanced()" class="md:ml-auto flex items-center gap-2 text-xs text-gray-400 hover:text-white px-3 py-1.5 rounded-lg hover:bg-gray-700 transition-colors">
                        <i class="fas fa-sliders-h"></i>
                        <span>Filtros avançados</span>
                        <i class="fas fa-chevron-down text-[10px] transition-transform duration-200" id="advanced-arrow"></i>
                    </button>
                </div>

                <!-- Date range (hidden by default) -->
                <div id="date-range-section" class="hidden flex flex-wrap items-center gap-2 border border-gray-700 rounded-lg px-3 py-2 bg-gray-900">
                    <span class="text-xs text-gray-500">De:</span>
                    <input type="datetime-local" id="input-from" class="bg-gray-800 text-white text-xs rounded px-2 py-1 border border-gray-600 focus:outline-none focus:border-green-500">
                    <span class="text-xs text-gray-500">Até:</span>
                    <input type="datetime-local" id="input-to" class="bg-gray-800 text-white text-xs rounded px-2 py-1 border border-gray-600 focus:outline-none focus:border-green-500">
                    <button onclick="applyDateRange()" class="bg-green-700 hover:bg-green-600 text-white text-xs px-3 py-1 rounded transition-colors">Aplicar</button>
                    <button onclick="clearDateRange()" class="text-gray-400 hover:text-white text-xs px-2 py-1 transition-colors">Cancelar</button>
                </div>

                <!-- Advanced Panel (hidden by default) -->
                <div id="advanced-panel" class="hidden border border-gray-700 rounded-lg p-4 bg-gray-900">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div>
                            <label class="text-xs text-gray-500 block mb-1.5">Mín. sessões ativas</label>
                            <input type="number" id="min-active" min="0" value="0" onchange="setMinActive(this.value)"
                                class="w-full bg-gray-800 text-white text-sm rounded px-2 py-1.5 border border-gray-600 focus:outline-none focus:border-green-500">
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 block mb-1.5">Mín. sessões iniciadas</label>
                            <input type="number" id="min-started" min="0" value="0" onchange="setMinStarted(this.value)"
                                class="w-full bg-gray-800 text-white text-sm rounded px-2 py-1.5 border border-gray-600 focus:outline-none focus:border-green-500">
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 block mb-1.5">Ordenar por</label>
                            <select id="sort-by" onchange="setSortBy(this.value)"
                                class="w-full bg-gray-800 text-white text-sm rounded px-2 py-1.5 border border-gray-600 focus:outline-none focus:border-green-500">
                                <option value="slot">Horário</option>
                                <option value="active">Mais ativas</option>
                                <option value="started">Mais iniciadas</option>
                            </select>
                        </div>
                        <div id="tenant-filter-wrap" class="hidden">
                            <label class="text-xs text-gray-500 block mb-1.5">Congregação</label>
                            <select id="tenant-select" onchange="setTenant(this.value)"
                                class="w-full bg-gray-800 text-white text-sm rounded px-2 py-1.5 border border-gray-600 focus:outline-none focus:border-green-500">
                                <option value="">Todas</option>
                            </select>
                        </div>
                    </div>
                    <div class="flex justify-end mt-3 pt-3 border-t border-gray-700">
                        <button onclick="clearFilters()" class="text-xs text-gray-400 hover:text-white px-3 py-1.5 rounded hover:bg-gray-700 transition-colors flex items-center gap-1.5">
                            <i class="fas fa-times"></i> Limpar filtros
                        </button>
                    </div>
                </div>

                <!-- Active Filter Chips -->
                <div id="active-chips" class="flex flex-wrap gap-2"></div>
            </div>

            <!-- Abas -->
            <div class="flex gap-2 mb-4 border-t border-gray-700 pt-4">
                <button id="tab-geral" onclick="switchTab('geral')"
                    class="px-4 py-1.5 rounded-lg text-sm font-semibold bg-green-600 text-white transition-colors">
                    Geral
                </button>
                <button id="tab-tenant" onclick="switchTab('tenant')"
                    class="px-4 py-1.5 rounded-lg text-sm font-semibold bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors">
                    Por Congregação
                </button>
            </div>

            <!-- Tabela Geral -->
            <div id="sessions-geral">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-gray-400 text-left border-b border-gray-700">
                            <th class="pb-2">Horário</th>
                            <th class="pb-2 text-right">Iniciadas</th>
                            <th class="pb-2 text-right">Ativas no período</th>
                        </tr>
                    </thead>
                    <tbody id="sessions-geral-body">
                        {{#if health.sessionsGeneral.length}}
                            {{#each health.sessionsGeneral}}
                            <tr class="table-row">
                                <td class="py-1.5 text-gray-300">{{slot}}</td>
                                <td class="py-1.5 text-right text-gray-400">{{started}}</td>
                                <td class="py-1.5 text-right font-bold text-white">{{active}}</td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr><td colspan="3" class="py-4 text-center text-gray-500">Nenhuma sessão registrada</td></tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
            <!-- Tabela Por Congregação -->
            <div id="sessions-tenant" class="hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-gray-400 text-left border-b border-gray-700">
                            <th class="pb-2">Horário</th>
                            <th class="pb-2">Congregação</th>
                            <th class="pb-2 text-right">Iniciadas</th>
                            <th class="pb-2 text-right">Ativas no período</th>
                        </tr>
                    </thead>
                    <tbody id="sessions-tenant-body">
                        {{#if health.sessionsByTenant.length}}
                            {{#each health.sessionsByTenant}}
                            <tr class="table-row">
                                <td class="py-1.5 text-gray-300">{{slot}}</td>
                                <td class="py-1.5 text-gray-300">{{tenant_name}}</td>
                                <td class="py-1.5 text-right text-gray-400">{{started}}</td>
                                <td class="py-1.5 text-right font-bold text-white">{{active}}</td>
                            </tr>
                            {{/each}}
                        {{else}}
                            <tr><td colspan="4" class="py-4 text-center text-gray-500">Nenhuma sessão registrada</td></tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        // ===== STATE =====
        let allSessionsGeneral = {{{sessionsGeneralJson}}};
        let allSessionsByTenant = {{{sessionsByTenantJson}}};
        let filters = {
            period: '1d', groupBy: '10min', from: '', to: '',
            onlyActive: false, minActive: 0, minStarted: 0, sortBy: 'slot', tenant: '',
        };
        let isAdvancedOpen = false;
        let currentTab = 'geral';

        // ===== CHIP CSS =====
        const CHIP_ACTIVE   = 'px-3 py-1 rounded-md text-xs font-semibold bg-green-700 text-white border border-green-600 transition-colors';
        const CHIP_INACTIVE = 'px-3 py-1 rounded-md text-xs font-semibold bg-gray-800 text-gray-400 border border-gray-700 hover:border-gray-500 hover:text-white transition-colors';
        const CHIP_ACTIVE_FILTER = 'inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs bg-gray-700 text-gray-200 border border-gray-600';

        // ===== TAB =====
        function switchTab(tab) {
            currentTab = tab;
            const isGeral = tab === 'geral';
            document.getElementById('sessions-geral').classList.toggle('hidden', !isGeral);
            document.getElementById('sessions-tenant').classList.toggle('hidden', isGeral);
            document.getElementById('tab-geral').className  = isGeral ? 'px-4 py-1.5 rounded-lg text-sm font-semibold bg-green-600 text-white transition-colors' : 'px-4 py-1.5 rounded-lg text-sm font-semibold bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors';
            document.getElementById('tab-tenant').className = isGeral ? 'px-4 py-1.5 rounded-lg text-sm font-semibold bg-gray-700 text-gray-300 hover:bg-gray-600 transition-colors' : 'px-4 py-1.5 rounded-lg text-sm font-semibold bg-green-600 text-white transition-colors';
            document.getElementById('tenant-filter-wrap').classList.toggle('hidden', isGeral);
            applyFilters();
        }

        // ===== PERIOD =====
        function setPeriod(p) {
            if (p === 'custom') {
                document.getElementById('date-range-section').classList.remove('hidden');
                document.querySelectorAll('[data-period]').forEach(btn => {
                    btn.className = btn.dataset.period === 'custom' ? CHIP_ACTIVE : CHIP_INACTIVE;
                });
                return;
            }
            filters.period = p;
            filters.from = '';
            filters.to = '';
            document.getElementById('date-range-section').classList.add('hidden');
            syncPeriodChips();
            fetchSessions();
        }

        function syncPeriodChips() {
            document.querySelectorAll('[data-period]').forEach(btn => {
                const isActive = btn.dataset.period !== 'custom' && btn.dataset.period === filters.period && !filters.from;
                btn.className = isActive ? CHIP_ACTIVE : CHIP_INACTIVE;
            });
        }

        // ===== GROUPBY =====
        function setGroupBy(g) {
            filters.groupBy = g;
            document.querySelectorAll('[data-groupby]').forEach(btn => {
                btn.className = btn.dataset.groupby === g ? CHIP_ACTIVE : CHIP_INACTIVE;
            });
            fetchSessions();
        }

        // ===== DATE RANGE =====
        function applyDateRange() {
            const from = document.getElementById('input-from').value;
            const to   = document.getElementById('input-to').value;
            if (!from || !to) { alert('Preencha as datas de início e fim.'); return; }
            if (new Date(from) >= new Date(to)) { alert('A data de início deve ser anterior à data de fim.'); return; }
            filters.from   = new Date(from).toISOString();
            filters.to     = new Date(to).toISOString();
            filters.period = '';
            syncPeriodChips();
            fetchSessions();
        }

        function clearDateRange() {
            filters.from = '';
            filters.to   = '';
            filters.period = '1d';
            document.getElementById('date-range-section').classList.add('hidden');
            document.getElementById('input-from').value = '';
            document.getElementById('input-to').value   = '';
            syncPeriodChips();
            fetchSessions();
        }

        // ===== ADVANCED PANEL =====
        function toggleAdvanced() {
            isAdvancedOpen = !isAdvancedOpen;
            document.getElementById('advanced-panel').classList.toggle('hidden', !isAdvancedOpen);
            document.getElementById('advanced-arrow').style.transform = isAdvancedOpen ? 'rotate(180deg)' : '';
        }

        // ===== QUICK TOGGLES =====
        function toggleOnlyActive(v) { filters.onlyActive = v; applyFilters(); }
        function setMinActive(v)   { filters.minActive  = Math.max(0, parseInt(v) || 0); applyFilters(); }
        function setMinStarted(v)  { filters.minStarted = Math.max(0, parseInt(v) || 0); applyFilters(); }
        function setSortBy(v)      { filters.sortBy = v; applyFilters(); }
        function setTenant(v)      { filters.tenant = v; applyFilters(); }

        // ===== CLEAR ALL =====
        function clearFilters() {
            filters = { period: '1d', groupBy: '10min', from: '', to: '', onlyActive: false, minActive: 0, minStarted: 0, sortBy: 'slot', tenant: '' };
            document.getElementById('date-range-section').classList.add('hidden');
            document.getElementById('input-from').value = '';
            document.getElementById('input-to').value   = '';
            document.getElementById('toggle-only-active').checked = false;
            document.getElementById('min-active').value  = 0;
            document.getElementById('min-started').value = 0;
            document.getElementById('sort-by').value     = 'slot';
            document.getElementById('tenant-select').value = '';
            syncPeriodChips();
            document.querySelectorAll('[data-groupby]').forEach(btn => {
                btn.className = btn.dataset.groupby === '10min' ? CHIP_ACTIVE : CHIP_INACTIVE;
            });
            fetchSessions();
        }

        // ===== REMOVE CHIP =====
        function removeChip(key) {
            const defaults = { period: '1d', groupBy: '10min', from: '', to: '', onlyActive: false, minActive: 0, minStarted: 0, sortBy: 'slot', tenant: '' };
            if (key === 'daterange') { clearDateRange(); return; }
            filters[key] = defaults[key];
            if (key === 'onlyActive') document.getElementById('toggle-only-active').checked = false;
            if (key === 'minActive')  document.getElementById('min-active').value  = 0;
            if (key === 'minStarted') document.getElementById('min-started').value = 0;
            if (key === 'sortBy')     document.getElementById('sort-by').value     = 'slot';
            if (key === 'tenant')     document.getElementById('tenant-select').value = '';
            applyFilters();
        }

        // ===== FETCH FROM API =====
        async function fetchSessions() {
            const params = new URLSearchParams({ groupBy: filters.groupBy });
            if (filters.from && filters.to) {
                params.set('from', filters.from);
                params.set('to',   filters.to);
            } else if (filters.period) {
                params.set('period', filters.period);
            }
            try {
                const res = await fetch(`/v1/sessions?${params}`);
                if (!res.ok) throw new Error('Falha ao buscar sessões');
                const data = await res.json();
                allSessionsGeneral  = data.sessionsGeneral;
                allSessionsByTenant = data.sessionsByTenant;
                populateTenantSelect();
                applyFilters();
            } catch (e) {
                console.error('Erro ao buscar sessões:', e);
            }
        }

        // ===== TENANT SELECT =====
        function populateTenantSelect() {
            const unique = [...new Set(allSessionsByTenant.map(s => s.tenant_name))].sort();
            const select  = document.getElementById('tenant-select');
            const current = filters.tenant;
            select.innerHTML = '<option value="">Todas</option>' +
                unique.map(t => `<option value="${t.replace(/"/g, '&quot;')}"${t === current ? ' selected' : ''}>${t}</option>`).join('');
        }

        // ===== APPLY CLIENT-SIDE FILTERS =====
        function applyFilters() {
            const { onlyActive, minActive, minStarted, sortBy, tenant } = filters;

            const filter = s => {
                if (onlyActive && s.active === 0) return false;
                if (s.active   < minActive)        return false;
                if (s.started  < minStarted)       return false;
                return true;
            };
            const sort = arr => {
                if (sortBy === 'active')  arr.sort((a, b) => b.active  - a.active);
                if (sortBy === 'started') arr.sort((a, b) => b.started - a.started);
                return arr;
            };

            const general  = sort(allSessionsGeneral.filter(filter));
            const byTenant = sort(allSessionsByTenant.filter(s => filter(s) && (!tenant || s.tenant_name === tenant)));

            document.getElementById('sessions-geral-body').innerHTML  = renderSessionRows(general, 3);
            document.getElementById('sessions-tenant-body').innerHTML = renderSessionRows(byTenant, 4);
            renderActiveChips();
        }

        // ===== RENDER ACTIVE CHIPS =====
        function renderActiveChips() {
            const chips = [];
            if (filters.from && filters.to) {
                const fmt = iso => new Date(iso).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo', day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
                chips.push({ label: `${fmt(filters.from)} → ${fmt(filters.to)}`, key: 'daterange' });
            }
            if (filters.onlyActive)      chips.push({ label: 'Apenas com atividade', key: 'onlyActive' });
            if (filters.minActive > 0)   chips.push({ label: `Mín. ativas ≥ ${filters.minActive}`, key: 'minActive' });
            if (filters.minStarted > 0)  chips.push({ label: `Mín. iniciadas ≥ ${filters.minStarted}`, key: 'minStarted' });
            if (filters.sortBy !== 'slot') chips.push({ label: `Ordenar: ${filters.sortBy === 'active' ? 'Mais ativas' : 'Mais iniciadas'}`, key: 'sortBy' });
            if (filters.tenant)          chips.push({ label: `Congregação: ${filters.tenant}`, key: 'tenant' });

            document.getElementById('active-chips').innerHTML = chips.map(c =>
                `<span class="${CHIP_ACTIVE_FILTER}">${c.label}<button onclick="removeChip('${c.key}')" class="ml-1 hover:text-green-400 font-bold">×</button></span>`
            ).join('');
        }

        // ===== RENDER TABLE ROWS =====
        function renderSessionRows(sessions, cols) {
            if (!sessions || sessions.length === 0) {
                return `<tr><td colspan="${cols}" class="py-4 text-center text-gray-500">Nenhuma sessão registrada</td></tr>`;
            }
            return sessions.map(s => {
                if (cols === 3) return `<tr class="table-row"><td class="py-1.5 text-gray-300">${s.slot}</td><td class="py-1.5 text-right text-gray-400">${s.started}</td><td class="py-1.5 text-right font-bold text-white">${s.active}</td></tr>`;
                return `<tr class="table-row"><td class="py-1.5 text-gray-300">${s.slot}</td><td class="py-1.5 text-gray-300">${s.tenant_name}</td><td class="py-1.5 text-right text-gray-400">${s.started}</td><td class="py-1.5 text-right font-bold text-white">${s.active}</td></tr>`;
            }).join('');
        }

        // ===== REFRESH ALL =====
        async function refreshData() {
            const btn  = document.querySelector('button[onclick="refreshData()"]') || document.querySelector('button');
            const icon = document.getElementById('refresh-icon');
            btn.disabled = true;
            if (icon) icon.classList.add('animate-spin');
            try {
                const [healthRes] = await Promise.all([fetch('/v1/health-check'), fetchSessions()]);
                const data = await healthRes.json();

                if (document.getElementById('last-update-time')) {
                    document.getElementById('last-update-time').innerText = new Date().toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo' });
                }
                document.getElementById('server-message').innerText    = data.message;
                document.getElementById('signatures-count').innerText  = data.signatures;
                document.getElementById('sockets-count').innerText     = data.sockets;
                document.getElementById('db-active').innerText         = data.database_info.active;
                document.getElementById('db-idle').innerText           = data.database_info.idle;
                document.getElementById('db-max').innerText            = data.database_info.max_connections;
                const dbPercent = ((data.database_info.active / data.database_info.max_connections) * 100).toFixed(1);
                document.getElementById('db-percent-text').innerText   = dbPercent + '%';
                document.getElementById('db-progress').style.width     = dbPercent + '%';
                document.getElementById('mem-percent-text').innerText  = data.system_info.memory_usage_percent + '%';
                document.getElementById('mem-progress').style.width    = data.system_info.memory_usage_percent + '%';
                document.getElementById('mem-total').innerText         = data.system_info.total_memory_mb + ' MB';
                document.getElementById('mem-used').innerText          = data.system_info.used_memory_mb  + ' MB';
                document.getElementById('mem-free').innerText          = data.system_info.free_memory_mb  + ' MB';
                document.getElementById('cpu-percent').innerText       = data.system_info.cpu_usage_percent + '%';
                document.getElementById('cpu-progress').style.width   = data.system_info.cpu_usage_percent + '%';
                const uptime = data.system_info.uptime_seconds;
                const ud = Math.floor(uptime / (3600 * 24));
                const uh = Math.floor(uptime % (3600 * 24) / 3600);
                const um = Math.floor(uptime % 3600 / 60);
                const us = Math.floor(uptime % 60);
                document.getElementById('uptime-text').innerText       = `${ud}d ${uh}h ${um}m ${us}s`;
                document.getElementById('load-1').innerText  = data.system_info.load_average['1_min'];
                document.getElementById('load-5').innerText  = data.system_info.load_average['5_min'];
                document.getElementById('load-15').innerText = data.system_info.load_average['15_min'];
            } catch (error) {
                console.error('Falha ao atualizar dados:', error);
                alert('Ocorreu um erro ao atualizar os dados de saúde.');
            } finally {
                btn.disabled = false;
                if (icon) icon.classList.remove('animate-spin');
            }
        }

        // ===== INIT =====
        populateTenantSelect();
    </script>
</body>
</html>
